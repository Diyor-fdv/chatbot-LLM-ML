APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# API auth (recommended for Power BI usage)
API_AUTH_ENABLED=true
API_KEYS=dev-local-key-1,dev-local-key-2

# SQLAlchemy URL, e.g. postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@localhost:5432/chatbot

# Optional LLM (OpenAI-compatible)
LLM_ENABLED=false
OPENAI_API_KEY=changeme
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Safety
MAX_ROWS=5000
DEFAULT_LIMIT=500
